---
type Header = {
  green: string;
  blue: string;
};

type Contact = {
  href: string;
  text: string;
};

const headers: Header[] = [
  {
    green: "Hello,\xa0I'm",
    blue: "Mihaly\xa0Furedi",
  },
  {
    green: "Located in",
    blue: "Budapest,\xa0Hungary,\xa0EU",
  },
];

const contacts: Contact[] = [
  {
    href: "mailto:mihaly@mihaly.dev",
    text: "e-mail",
  },
  {
    href: "https://linkedin.mihaly.dev",
    text: "LinkedIn",
  },
  {
    href: "https://github.mihaly.dev",
    text: "GitHub",
  },
];
---

<header
  class="flex flex-col md:flex-row justify-start md:justify-between flex-wrap gap-y-6 cursor-default"
>
  <div>
    <div class="font-silkscreen text-xl flex flex-col xl:flex-row xl:space-x-3">
      <span class="text-primary-green">{headers[0].green}</span>
      <span class="text-primary-blue">{headers[0].blue}</span>
    </div>
    <ul class="font-silkscreen text-sm text-primary-black pt-3 flex flex-wrap gap-x-4 gap-y-2 cursor-auto">
      {
        contacts.map((contact) => {
          return (
            <li>
              <a
                href={contact.href}
                target="_blank"
                rel="noreferrer"
                class="outline-hidden ring-offset-4 ring-transparent ring-4 focus:ring-[papayawhip] hover:ring-[papayawhip] underline-offset-4 focus:underline"
              >
                &gt;&nbsp;{contact.text}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
  <div class="font-silkscreen text-xl flex flex-col xl:flex-row xl:space-x-3">
    <span class="text-primary-green">{headers[1].green}</span>
    <span class="text-primary-blue">{headers[1].blue}</span>
  </div>
</header>
