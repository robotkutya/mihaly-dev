---
import { profile } from '../data/profile';
import ThemeToggle from './ThemeToggle.astro';

type Header = {
  green: string;
  blue: string;
};

const name = profile.identity.name.replaceAll(' ', '\u00a0');
const location = profile.identity.location.replaceAll(' ', '\u00a0');

const headers: Header[] = [
  {
    green: "Hello,\xa0I'm",
    blue: name,
  },
  {
    green: "Located in",
    blue: location,
  },
];

const contacts = profile.links.filter((link) => link.showInHeader);
---

<header
  class="flex flex-col md:flex-row justify-start md:justify-between flex-wrap gap-y-6 cursor-default"
>
  <div>
    <div class="font-silkscreen text-xl flex flex-col xl:flex-row xl:space-x-3">
      <span class="text-primary-green">{headers[0].green}</span>
      <span class="text-primary-blue">{headers[0].blue}</span>
    </div>
    <ul class="font-silkscreen text-sm text-primary-black pt-3 flex flex-wrap gap-x-4 gap-y-2 cursor-auto">
      {
        contacts.map((contact) => {
          return (
            <li>
              <a
                href={contact.href}
                target="_blank"
                rel="noreferrer"
                class="cursor-pointer outline-hidden ring-offset-4 ring-offset-[var(--color-page)] ring-transparent ring-4 transition-colors hover:text-primary-yellow focus:text-primary-yellow focus:ring-primary-yellow underline-offset-4"
              >
                <span class="text-primary-yellow">&gt;</span>&nbsp;{contact.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <ul class="font-silkscreen text-sm text-primary-black pt-2 flex flex-wrap gap-x-4 gap-y-2 cursor-auto">
      <li>
        <a
          href="/AGENTS.md"
          rel="agent-instructions"
          class="cursor-pointer outline-hidden ring-offset-4 ring-offset-[var(--color-page)] ring-transparent ring-4 transition-colors hover:text-primary-yellow focus:text-primary-yellow focus:ring-primary-yellow underline-offset-4"
        >
          <span class="text-primary-yellow">&gt;</span>&nbsp;agents.md
        </a>
      </li>
    </ul>
  </div>
  <div class="md:flex md:flex-col md:items-end">
    <div class="font-silkscreen text-xl flex flex-col xl:flex-row xl:space-x-3">
      <span class="text-primary-green">{headers[1].green}</span>
      <span class="text-primary-blue">{headers[1].blue}</span>
    </div>
    <ThemeToggle />
  </div>
</header>
