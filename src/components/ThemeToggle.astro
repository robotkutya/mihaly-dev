<button
  type="button"
  data-theme-toggle
  class="mt-3 inline-flex cursor-pointer items-center gap-2 border border-primary-yellow px-2 py-1 font-silkscreen text-sm text-primary-yellow outline-hidden ring-4 ring-transparent ring-offset-4 ring-offset-[var(--color-page)] transition-colors hover:bg-primary-yellow hover:text-[var(--color-page)] focus:ring-[papayawhip]"
  aria-label="Switch color theme"
>
  <svg
    data-theme-icon="sun"
    aria-hidden="true"
    viewBox="0 0 24 24"
    class="size-4 transition-opacity"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <span data-theme-toggle-label>theme</span>
  <svg
    data-theme-icon="moon"
    aria-hidden="true"
    viewBox="0 0 24 24"
    class="size-4 transition-opacity"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
  >
    <path d="M20.99 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 20.99 12.79z"></path>
  </svg>
</button>

<script>
  type Theme = "dark" | "light";
  type ThemeMode = Theme | "system";

  const themeStorageKey = "theme";
  const toggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const label = toggle?.querySelector<HTMLElement>("[data-theme-toggle-label]");
  const media = window.matchMedia("(prefers-color-scheme: dark)");

  const getSystemTheme = (): Theme => {
    return media.matches ? "dark" : "light";
  };

  const isThemeMode = (mode: string | undefined | null): mode is ThemeMode => {
    return mode === "system" || mode === "light" || mode === "dark";
  };

  const resolveTheme = (mode: ThemeMode): Theme => {
    return mode === "system" ? getSystemTheme() : mode;
  };

  const getStoredMode = (): ThemeMode => {
    try {
      const mode = localStorage.getItem(themeStorageKey);
      return isThemeMode(mode) ? mode : "system";
    } catch {
      return "system";
    }
  };

  const getMode = (): ThemeMode => {
    const mode = document.documentElement.dataset.themeMode;
    return isThemeMode(mode) ? mode : getStoredMode();
  };

  const storeMode = (mode: ThemeMode) => {
    try {
      if (mode === "system") {
        localStorage.removeItem(themeStorageKey);
        return;
      }

      localStorage.setItem(themeStorageKey, mode);
    } catch {
      return;
    }
  };

  const setTheme = (mode: ThemeMode) => {
    const resolvedTheme = resolveTheme(mode);

    document.documentElement.dataset.themeMode = mode;
    document.documentElement.dataset.theme = resolvedTheme;
    toggle?.setAttribute("aria-label", `Theme: ${mode}. Switch color theme.`);
    toggle?.setAttribute("title", `Theme: ${mode}`);

    if (label) {
      label.textContent = mode;
    }
  };

  setTheme(getMode());

  toggle?.addEventListener("click", () => {
    const mode = getMode();
    const nextMode: ThemeMode = mode === "system" ? "light" : mode === "light" ? "dark" : "system";

    setTheme(nextMode);
    storeMode(nextMode);
  });

  media.addEventListener("change", (event) => {
    if (getMode() !== "system") {
      return;
    }

    document.documentElement.dataset.theme = event.matches ? "dark" : "light";
  });
</script>
