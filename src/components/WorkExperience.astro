---
import { profile } from '../data/profile';

const roles = profile.experience;
---

<section class="md:col-span-2 pt-8 md:pt-12 xl:pt-16">
  <h2 class="font-silkscreen text-xl text-primary-black pb-6 md:pb-8">
    Professional Experience
  </h2>
  <ol class="space-y-8">
    {
      roles.map((role) => {
        return (
          <li class="grid md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] md:gap-12 xl:gap-24 border-t border-primary-light-gray pt-6">
            <div>
              <h3 class="font-silkscreen text-lg text-primary-blue">
                {role.title}
              </h3>
              <p class="font-inter text-base leading-7 text-primary-black">
                {role.company}
              </p>
            </div>
            <div>
              <p class="font-inter text-base leading-7 text-primary-gray">
                {role.dates} · {role.duration}
              </p>
              {
                role.location && (
                  <p class="font-inter text-base leading-7 text-primary-gray">
                    {role.location}
                  </p>
                )
              }
              {
                role.description && (
                  <p class="font-inter text-base leading-7 text-primary-black pt-3">
                    {role.description}
                  </p>
                )
              }
            </div>
          </li>
        );
      })
    }
  </ol>
</section>
